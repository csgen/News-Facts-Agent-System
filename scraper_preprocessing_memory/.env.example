# =============================================================================
# Neo4j Aura (Graph DB)
# =============================================================================
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# =============================================================================
# ChromaDB Cloud (Vector DB)
# =============================================================================
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_here
CHROMA_DATABASE=your_database_here

# =============================================================================
# OpenAI API (claim + entity extraction via gpt-4o-mini, image caption via gpt-4o)
# =============================================================================
OPENAI_API_KEY=sk-your_openai_key_here

# =============================================================================
# Google AI Studio (embeddings via gemini-embedding-001)
# =============================================================================
GOOGLE_API_KEY=your_google_ai_studio_key_here

# =============================================================================
# Tavily Search API (1000 free credits/month)
# =============================================================================
TAVILY_API_KEY=tvly-your_tavily_key_here

# =============================================================================
# Telegram Scraper API (optional, hosted on Google Cloud)
# =============================================================================
TELEGRAM_SCRAPER_API_URL=https://your-cloud-run-url.run.app
TELEGRAM_SCRAPER_API_KEY=your_api_key_here

# =============================================================================
# EnsembleData API (Reddit keyword search — replacement for blocked Telegram)
# =============================================================================
ENSEMBLEDATA_API_TOKEN=your_ensembledata_token_here

# =============================================================================
# Langfuse (LLM observability — free Hobby tier at langfuse.com)
# =============================================================================
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Optional overrides
# =============================================================================
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o
