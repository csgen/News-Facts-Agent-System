# =============================================================================
# news_facts_system — unified environment variables (merged across all 3 parts)
#
# 1. `cp .env.example .env`
# 2. Fill in the API keys / DB credentials for the mode you want to run.
#
# There is no CLI flag for cloud-vs-local: the subsystems branch on env-var
# presence. Leave a block blank to disable its path.
# =============================================================================


# ─── STACK TOGGLES ───────────────────────────────────────────────────────────
# openai  → use OpenAI cloud API for chat LLM
# ollama  → use local Ollama server (requires --profile ollama)
LLM_PROVIDER=openai

# gemini  → use Google Gemini embeddings (scapper's default, 1536-dim)
# openai  → use OpenAI text-embedding-3-small (1536-dim; requires re-seeding Chroma if switched)
# ollama  → use Ollama nomic-embed-text (768-dim; REQUIRES wiping Chroma)
EMBEDDING_PROVIDER=gemini


# ─── NEO4J ──────────────────────────────────────────────────────────────────
# Cloud (Neo4j Aura) — default for Chen
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
# Local container alternative (requires --profile neo4j):
#   NEO4J_URI=bolt://neo4j:7687
#   NEO4J_PASSWORD=fakenews123


# ─── CHROMADB ───────────────────────────────────────────────────────────────
# Pick ONE of the three modes below by filling its fields and leaving the others blank.
#
# (a) Chroma Cloud — set all three; leave CHROMA_HOST blank
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_here
CHROMA_DATABASE=your_database_here
#
# (b) Local Docker Chroma — set HOST (=service name inside compose) and PORT;
#     leave CHROMA_API_KEY blank. Requires --profile chroma.
CHROMA_HOST=
CHROMA_PORT=8000
#
# (c) Embedded (in-process) — leave everything blank; ChromaDB runs inside the process
#     (suitable only for dev / tests, not for the UI).


# ─── API KEYS ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
GOOGLE_API_KEY=your_google_ai_studio_key_here
TAVILY_API_KEY=tvly-your_tavily_key_here


# ─── MODEL NAMES (safe defaults — override to experiment) ───────────────────
LLM_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536


# ─── OLLAMA (only used when *_PROVIDER=ollama) ──────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_LLM_MODEL=gemma2:2b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VLM_MODEL=


# ─── OPTIONAL SCRAPER DATA SOURCES ──────────────────────────────────────────
TELEGRAM_SCRAPER_API_URL=
TELEGRAM_SCRAPER_API_KEY=
ENSEMBLEDATA_API_TOKEN=


# ─── LANGFUSE OBSERVABILITY (optional; off by default) ──────────────────────
# How the two subsystems opt in/out of Langfuse:
#
#   scraper_preprocessing_memory
#       Langfuse wires in at import time (@observe decorators + langfuse.openai).
#       The ONLY way to disable it is to leave LANGFUSE_PUBLIC_KEY and
#       LANGFUSE_SECRET_KEY blank — the SDK then silently no-ops on every call.
#       LANGFUSE_ENABLED / LANGFUSE_TRACING_ENABLED below DO NOT affect scapper.
#
#   FakeNewsAgent
#       Reads LANGFUSE_ENABLED and LANGFUSE_TRACING_ENABLED and skips tracing
#       when either is "false", regardless of the keys.
#
# Simplest "fully off" setup → leave PUBLIC_KEY + SECRET_KEY blank. That disables
# Langfuse for both modules.
LANGFUSE_ENABLED=false
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Local compose (requires --profile langfuse) →  http://langfuse:3000
# Cloud Hobby tier                            →  https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com


# ─── LANGSMITH (optional) ───────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=news-facts-system


# ─── RETRIEVAL / AGENT FEATURE FLAGS ────────────────────────────────────────
USE_GRAPH_RAG=false
USE_CROSS_ENCODER=false
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

USE_SIGLIP=false
SIGLIP_MODEL=google/siglip-base-patch16-224
SIGLIP_THRESHOLD=0.10

USE_RETRIEVAL_GATE=false
USE_CLAIM_DECOMPOSITION=false
USE_DEBATE=false
DEBATE_CONFIDENCE_THRESHOLD=70
USE_FRESHNESS_REACT=false
USE_CROSS_MODAL=false


# ─── EVAL / BENCHMARK FLAGS ─────────────────────────────────────────────────
DRY_RUN=false
OFFLINE_MODE=false
