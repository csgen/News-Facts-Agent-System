# ─────────────────────────────────────────────────────────────────────────────
# FactGuard — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Neo4j Graph DB ────────────────────────────────────────────────────────────
# Default: local Docker instance (see docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fakenews123

# ── ChromaDB Vector DB ────────────────────────────────────────────────────────
# Leave CHROMA_API_KEY empty to use a local Docker ChromaDB instance.
# Set host/port if running ChromaDB in Docker (default: localhost:8000).
CHROMA_API_KEY=
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Tavily Search API (live web search + scraper) ─────────────────────────────
TAVILY_API_KEY=tvly-...

# ── NewsAPI (optional RSS/News scraper) ───────────────────────────────────────
NEWSAPI_KEY=

# ── Telegram Scraper (optional — remote API proxy) ────────────────────────────
TELEGRAM_SCRAPER_API_URL=
TELEGRAM_SCRAPER_API_KEY=

# ── LangFuse Observability (optional) ────────────────────────────────────────
# If not set, the system uses standard OpenAI client without tracing.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── LLM Settings ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai          # "openai" | "ollama"
LLM_MODEL=gpt-4o-mini        # or "llama3" for Ollama
EMBEDDING_MODEL=text-embedding-3-small

# ── Feature Flags ─────────────────────────────────────────────────────────────
USE_GRAPH_RAG=false           # enable Neo4j GraphRAG path in retrieval
USE_DEBATE=false              # enable multi-agent debate node
DEBATE_CONFIDENCE_THRESHOLD=70
OFFLINE_MODE=false            # skip live search (Tavily)
DRY_RUN=false                 # skip all DB writes (for testing)
USE_RERANKER=false            # enable cross-encoder reranking
USE_CROSS_MODAL=false         # enable SigLIP/CLIP cross-modal check
